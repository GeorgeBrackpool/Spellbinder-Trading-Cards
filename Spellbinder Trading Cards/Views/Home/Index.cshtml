@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

    <div class="bg-primary">
            <!-- Hero Section -->
        <section class="hero-section">
            <div class="hero-overlay"></div>

            <div class="container hero-content">
                <div class="hero-text">
                    <span class="hero-tag">
                        WELCOME TO SPELLBINDER
                    </span>

                    <h1>
                        Discover Rare Cards.<br />
                        Forge your collection.
                    </h1>

                    <p>
                        Browse singles, sealed products and collector favourites.
                        Start your next trading card adventure today.
                    </p>

                    <div class="hero-buttons">
                        <a asp-controller="Products"
                           asp-action="Index"
                           class="btn-primary-custom">
                        <i class="fa-solid fa-bag-shopping fa-xl m-2"></i>Shop Cards
                        </a>

                        <a asp-controller="Collections"
                           asp-action="Index"
                           class="btn-secondary-custom">
                        <i class="fa-solid fa-vault fa-xl m-2"></i>Browse Your Vault
                        </a>
                    </div>
                </div>
            </div>
        </section>
        <!--End of Hero-->

    <section class="features-section">
    <div class="container text-center mw-100 mh-auto" id="card-col">
        <div class="row g-4">
            <div class="col">
                <div class="d-flex align-items-center justify-content-center m-3">
                    <div class="me-3">
                <i class="fa-solid fa-shield fa-2xl"></i>
                    </div>
                <div class="text-start">
                <h4>Secure Shopping</h4>
                <p>Shop with confidence.</p>
                    </div>
                </div>
            </div>
                <div class="col">
                    <div class="d-flex align-items-center justify-content-center m-3">
                        <div class="me-3">
                            <i class="fa-solid fa-truck fa-2xl"></i>
                        </div>
                        <div class="text-start">
                            <h4>Fast Delivery</h4>
                            <p>Quick and reliable delivery on all orders.</p>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="d-flex align-items-center justify-content-center m-3">
                        <div class="me-3">
                            <i class="fa-solid fa-user-group fa-2xl"></i>
                        </div>
                        <div class="text-start">
                            <h4>Built for Collectors</h4>
                            <p>Everything you need to build and manage your collection.</p>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="d-flex align-items-center justify-content-center m-3">
                        <div class="me-3">
                            <i class="fa-solid fa-star fa-2xl"></i>
                        </div>
                        <div class="text-start">
                            <h4>High Quality</h4>
                            <p>Cards in excellent condition and protected in transit.</p>
                        </div>
                    </div>
                </div>
        </div>
    </div>
    </section>
    <div class="container text-center pt-5">
        <div class="row">
            <div class="col bg-white">
                <div class="card" style="width: 18rem;">
                    <img src="~/assets/images/Cards/blue-eyes-placeholder.jpeg" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Card title</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                        <a href="#" class="btn btn-primary">Go somewhere</a>
                    </div>
                </div>
            </div>
            <div class="col bg-white">
                <div class="card" style="width: 18rem;">
                    <img src="~/assets/images/Cards/blue-eyes-placeholder.jpeg" class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Card title</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                        <a href="#" class="btn btn-primary">Go somewhere</a>
                    </div>
                </div>
            </div>
            <div class="col bg-white">
                <div class="card" style="width: 18rem;">
                    <img src="~/assets/images/Cards/blue-eyes-placeholder.jpeg" class="img-fluid rounded-start" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Card title</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                        <a href="#" class="btn btn-primary">Go somewhere</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
